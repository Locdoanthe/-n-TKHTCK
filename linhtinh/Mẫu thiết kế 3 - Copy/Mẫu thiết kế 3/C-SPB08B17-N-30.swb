cLn part,wMat,-0.028,0.015,0,0.015
cLn part,wMat,0,0.015,0,0.0306
cArc part,wMat,0,0.0306,-0.00024156378332893,0.0338829636065113,-0.0013,0.037
cLn part,wMat,-0.0013,0.037,-0.0059,0.037
cArc part,wMat,-0.0059,0.037,-0.00695843621667107,0.0338829636065113,-0.0072,0.0306
cLn part,wMat,-0.0072,0.0306,-0.0072,0.026
cLn part,wMat,-0.0072,0.026,-0.02735,0.026
cLn part,wMat,-0.02735,0.026,-0.028,0.02535
cCLn part,wMat,0,0,-0.0036,0
Part.SketchManager.InsertSketch True
end sub

