feat9.select2 false,0
featMgr.FeatureRevolveCut2 6.28318530717959,1,6.28318530717959,0,0,1,1,false,false,false
 if getEdgeFromModel(part,createVec3d(1.59204083889156e-18,0.0253235,0.0176765),cylEdge) then
