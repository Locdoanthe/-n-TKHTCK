customPropMgr.Add2 "PN", 30, "C-SPB10B23-N-25"
customPropMgr.Add2 "NT", 30, "23"
customPropMgr.Add2 "SPEC", 30, "New JIS Key Groove Hole Tapped"
customPropMgr.Add2 "D", 30, "25"
customPropMgr.Add2 "DPP", 30, "116.58"
customPropMgr.Add2 "DOO", 30, "123.5"
customPropMgr.Add2 "H", 30, "80"
customPropMgr.Add2 "L", 30, "30"
customPropMgr.Add2 "LL", 30, "7.0"
customPropMgr.Add2 "M", 30, "8"
customPropMgr.Add2 "BBTT", 30, "8x3.3"
customPropMgr.Add2 "SUPPLIER", 30, "MISUMI"
customPropMgr.Add2 "ARTICLENO", 30, "C-SPB10B23-N-25"
customPropMgr.Add2 "BOMINFO", 30, "C-SPB10B23-N-25"
customPropMgr.Add2 "CREATOR", 30, "CADENAS GmbH"
customPropMgr.Add2 "IsFastener", 30, "0"
part.SummaryInfo(0)="C-SPB10B23-N-25"
part.SummaryInfo(4)="Economy Sprocket10B"
part.SummaryInfo(2)="Cadenas PARTsolutions"
valRGB=part.MaterialPropertyValues
valRGB(0)=0.689999997615814
valRGB(1)=0.689999997615814
valRGB(2)=0.689999997615814
valRGB(7)=0
part.MaterialPropertyValues=valRGB
Dim featMgr as object
set featMgr = part.FeatureManager
codeBag0 part,featMgr
part.ActiveView.EnableGraphicsUpdate = true
part.SketchManager.DisplayWhenAdded = true
part.SketchManager.AddToDB = false
part.EditRebuild3
part.Rebuild swRebuildAll
Set modelExt = part.Extension
modelExt.SaveAs storePath & "C-SPB10B23-N-25.sldprt",0,0,nothing,errors,warnings
swApp.CloseDoc storePath &"C-SPB10B23-N-25.sldprt"
End Sub
