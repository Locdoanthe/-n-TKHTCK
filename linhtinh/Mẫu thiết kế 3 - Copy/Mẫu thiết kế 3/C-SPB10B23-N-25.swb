cLn part,wMat,-0.03,0.0125,0,0.0125
cLn part,wMat,0,0.0125,0,0.05385
cArc part,wMat,0,0.05385,-0.000294370755506101,0.0579024059229355,-0.0016,0.06175
cLn part,wMat,-0.0016,0.06175,-0.0075,0.06175
cArc part,wMat,-0.0075,0.06175,-0.0088056292444939,0.0579024059229355,-0.0091,0.05385
cLn part,wMat,-0.0091,0.05385,-0.0091,0.04
cLn part,wMat,-0.0091,0.04,-0.02935,0.04
cLn part,wMat,-0.02935,0.04,-0.03,0.03935
cCLn part,wMat,0,0,-0.00455,0
Part.SketchManager.InsertSketch True
end sub

